---
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-grid">
  <div class="absolute inset-0">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-violet-600/20 rounded-full blur-[128px] animate-[pulse-glow_4s_ease-in-out_infinite]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-cyan-600/20 rounded-full blur-[128px] animate-[pulse-glow_4s_ease-in-out_infinite_2s]"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-violet-500/10 rounded-full blur-[200px] animate-[pulse-glow_6s_ease-in-out_infinite_1s]"></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
    <div class="animate-[slide-up_1s_ease-out]">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-violet-500/10 border border-violet-500/20 rounded-full text-sm text-violet-400 mb-8">
        <span class="w-2 h-2 bg-violet-400 rounded-full animate-pulse"></span>
        Claude, OpenCode, Gemini
      </div>
    </div>

    <h1 class="text-5xl md:text-7xl lg:text-8xl font-black mb-6 animate-[slide-up_1s_ease-out_0.2s_both]">
      <span class="text-gradient-animated">IA que responde</span>
      <br />
      <span class="text-white">como yo quiero</span>
    </h1>

    <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto mb-12 animate-[slide-up_1s_ease-out_0.4s_both]">
      Perfiles de instrucciones para que las IA respondan directo, sin relleno, sin frases de cortesía. 
      <span class="text-white font-medium">63% menos de tokens.</span>
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-[slide-up_1s_ease-out_0.6s_both]">
      <a href="#instalacion" class="group relative px-8 py-4 bg-violet-600 hover:bg-violet-500 rounded-xl font-semibold transition-all hover:shadow-lg hover:shadow-violet-500/25">
        <span class="relative z-10">Empezar ahora</span>
        <div class="absolute inset-0 bg-gradient-to-r from-violet-600 to-cyan-600 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
      </a>
      <a href="https://github.com/Haplee/token-efficiency" target="_blank" rel="noopener" class="px-8 py-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl font-semibold transition-all hover:border-violet-500/50">
        Ver en GitHub
      </a>
    </div>

    <div class="mt-20 grid grid-cols-3 gap-8 max-w-lg mx-auto animate-[fade-in_1s_ease-out_0.8s_both]">
      <div class="text-center">
        <div class="text-3xl font-bold text-gradient">63%</div>
        <div class="text-xs text-gray-500 mt-1">Tokens ahorrados</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-bold text-gradient">3</div>
        <div class="text-xs text-gray-500 mt-1">IA soportadas</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-bold text-gradient">5</div>
        <div class="text-xs text-gray-500 mt-1">Perfiles</div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-[float_3s_ease-in-out_infinite]">
    <div class="w-6 h-10 border-2 border-white/20 rounded-full flex justify-center">
      <div class="w-1 h-3 bg-violet-400 rounded-full mt-2 animate-[counter_1.5s_ease-in-out_infinite]"></div>
    </div>
  </div>
</section>
