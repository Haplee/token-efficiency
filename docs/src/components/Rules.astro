---
---

<section id="estilo" class="py-32 bg-grid relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-20 animate-on-scroll">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        Mi <span class="text-gradient-animated">estilo</span>
      </h2>
      <p class="text-gray-400 max-w-xl mx-auto">
        Las reglas que definen cómo quiero que las IA me respondan. Sin excepciones.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      <div class="animate-on-scroll delay-1 group relative bg-white/[0.02] border border-white/5 rounded-2xl p-8 card-hover">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-red-500/10 rounded-lg flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold mb-2 text-red-400">Lo que NUNCA hacer</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 bg-red-400 rounded-full"></span>
                Sin "¡Claro!" o "Con gusto"
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 bg-red-400 rounded-full"></span>
                Sin "Espero que te ayude"
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 bg-red-400 rounded-full"></span>
                Sin código incompleto o TODOs
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 bg-red-400 rounded-full"></span>
                Sin sobreingeniería
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 bg-red-400 rounded-full"></span>
                Sin explicar conceptos básicos ASIR
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 bg-red-400 rounded-full"></span>
                Sin tests si no se piden
              </li>
            </ul>
          </div>
        </div>
      </div>

      <div class="animate-on-scroll delay-2 group relative bg-white/[0.02] border border-white/5 rounded-2xl p-8 card-hover">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-emerald-500/10 rounded-lg flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold mb-2 text-emerald-400">Lo que SIEMPRE hacer</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 bg-emerald-400 rounded-full"></span>
                Código completo y ejecutable
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 bg-emerald-400 rounded-full"></span>
                Respuesta directa al problema
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 bg-emerald-400 rounded-full"></span>
                Primero lo simple, luego lo óptimo
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 bg-emerald-400 rounded-full"></span>
                Comandos de instalación si hacen falta
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 bg-emerald-400 rounded-full"></span>
                Linux por defecto
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 bg-emerald-400 rounded-full"></span>
                Open source siempre
              </li>
            </ul>
          </div>
        </div>
      </div>

      <div class="animate-on-scroll delay-3 group relative bg-white/[0.02] border border-white/5 rounded-2xl p-8 card-hover md:col-span-2">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-violet-500/10 rounded-lg flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold mb-4 text-violet-400">Stack preferido</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <div class="bg-white/5 rounded-lg p-3 text-center">
                <div class="text-xs text-gray-500 mb-1">SO</div>
                <div class="text-sm font-medium">Ubuntu / Debian</div>
              </div>
              <div class="bg-white/5 rounded-lg p-3 text-center">
                <div class="text-xs text-gray-500 mb-1">Backend</div>
                <div class="text-sm font-medium">Python + Flask</div>
              </div>
              <div class="bg-white/5 rounded-lg p-3 text-center">
                <div class="text-xs text-gray-500 mb-1">Scripting</div>
                <div class="text-sm font-medium">Python · Bash</div>
              </div>
              <div class="bg-white/5 rounded-lg p-3 text-center">
                <div class="text-xs text-gray-500 mb-1">DB</div>
                <div class="text-sm font-medium">MariaDB / SQLite</div>
              </div>
              <div class="bg-white/5 rounded-lg p-3 text-center">
                <div class="text-xs text-gray-500 mb-1">Web</div>
                <div class="text-sm font-medium">Nginx / Apache</div>
              </div>
              <div class="bg-white/5 rounded-lg p-3 text-center">
                <div class="text-xs text-gray-500 mb-1">Frontend</div>
                <div class="text-sm font-medium">React + TS</div>
              </div>
              <div class="bg-white/5 rounded-lg p-3 text-center">
                <div class="text-xs text-gray-500 mb-1">Contenedores</div>
                <div class="text-sm font-medium">Docker</div>
              </div>
              <div class="bg-white/5 rounded-lg p-3 text-center">
                <div class="text-xs text-gray-500 mb-1">Versiones</div>
                <div class="text-sm font-medium">Git</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
